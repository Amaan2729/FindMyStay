# Test environment variables
NODE_ENV=test

# Email Service
EMAIL_USER=test@example.com
EMAIL_PASS=testpassword
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Database (use test database)
DB_HOST=localhost
DB_USER=test_user
DB_PASSWORD=test_password
DB_NAME=findmystay_test

# API Configuration
API_URL=http://localhost:3000
API_PORT=3001

# JWT (use test token)
JWT_SECRET=test_secret_key_123

# Firebase (test credentials)
FIREBASE_PROJECT_ID=findmystay-test
FIREBASE_API_KEY=test_api_key

# Disable external integrations in tests
DISABLE_EXTERNAL_API=true
